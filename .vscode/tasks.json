{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Walnut: Run current file",
            "type": "shell",
            "command": "f='${relativeFileDirname}/${fileBasenameNoExtension}'; ${workspaceFolder}/bin/almond-cli \"${f#almond/walnut-src/}\"",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Walnut: Run current test file",
            "type": "shell",
            "command": "d='${relativeFileDirname}'; d=\"${d#almond/walnut-src}\"; d=\"${d#/}\"; [ -z \"$d\" ] && d='.'; ${workspaceFolder}/bin/almond-test \"$d\"",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Walnut: Analyse workspace",
            "type": "shell",
            "command": "${workspaceFolder}/bin/almond-analyse",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}