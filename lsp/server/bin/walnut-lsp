#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use Walnut\Lang\Lsp\Implementation\Transport\StdioTransport;
use Walnut\Lang\Lsp\Implementation\Server\JsonRpcLspServer;

// Ensure PHP errors never reach stdout (which is reserved for JSON-RPC messages).
ini_set('display_errors', '0');
ini_set('log_errors', '1');
ini_set('error_log', 'php://stderr');

$transport = new StdioTransport();
$server    = new JsonRpcLspServer($transport);
$server->run();
